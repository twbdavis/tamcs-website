# Supabase — copy to .env.local and fill in your project's values.
# Find these at: https://supabase.com/dashboard/project/_/settings/api

# Public values (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Server-only secret — NEVER expose to client code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
